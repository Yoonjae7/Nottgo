# Google Analytics 4 — create a Web data stream in GA4 and paste the Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Maps — enable Maps JavaScript API in Cloud Console, create an API key
# https://console.cloud.google.com/apis/library/maps-backend.googleapis.com
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Eup fleet API (server-only — never NEXT_PUBLIC_)
# Token from campus transport; plate must match their system exactly.
EUP_TOKEN=
# One plate or comma-separated: PLATE1,PLATE2,PLATE3
EUP_CAR_NUMBER=
# Optional override (default: https://my-slt.eupfin.com/Eup_Servlet_API_SOAP)
# EUP_BASE_URL=
